  "clueByIntent": {
    "look": [
      "You take in the scene carefully. Something here is staged, but one physical detail refuses to fit.",
      "You notice a pressure pattern: the danger is not everywhere, only where the story wants you to look.",
      "A mundane detail has supernatural weight. Mark it as a clue before the scene changes."
    ],
    "investigate": [
      "The evidence narrows the threat. Remove one false possibility.",
      "The clue connects motive, method, or anchor. The case is less random than it looked.",
      "You find a contradiction. Someone or something wants the wrong theory to survive."
    ],
    "talk": [
      "The witness reveals an emotional truth, but not necessarily a factual one.",
      "Their phrasing repeats something from another source. That repetition matters.",
      "They know more than they can safely say. Pressure could help, but compassion may reveal more."
    ],
    "research": [
      "Records confirm an older pattern. This has happened before under another name.",
      "The archive gives you 2\u20133 possible entity types, not certainty.",
      "A prior Warden note mentions a weakness but leaves out the kill condition."
    ],
    "prep": [
      "Your preparation reduces future danger if the theory is right.",
      "The gear setup works, but only against the correct type of threat.",
      "You convert knowledge into leverage: trap, ward, bait, witness, or escape route."
    ],
    "use": [
      "The object reacts, revealing whether your theory is close.",
      "The tool helps, but the scene pushes back with cost or noise.",
      "The item creates a narrow opening. Someone must act before it closes."
    ],
    "cast": [
      "The occult pressure answers. The rite can work, but it demands stability.",
      "The circle bites into the scene. You reveal a structure, anchor, or resistance.",
