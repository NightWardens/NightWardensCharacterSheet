{
  "name": "Night Wardens Auto-GM Web Engine",
  "version": "1.0",
  "majorArcana": [
    {
      "name": "The Fool",
      "theme": "Unknown beginning",
      "upright": "Open a hidden layer, new force, or second thread.",
      "reversed": "Walk into the wrong story; assumptions fail."
    },
    {
      "name": "The Magician",
      "theme": "Power and control",
      "upright": "Add tools, leverage, or a deliberate supernatural method.",
      "reversed": "Power destabilizes and turns unsafe."
    },
    {
      "name": "The High Priestess",
      "theme": "Hidden truth",
      "upright": "Reveal the real nature of a threat or key secret.",
      "reversed": "False certainty or misleading evidence."
    },
    {
      "name": "The Empress",
      "theme": "Growth",
      "upright": "Spread influence, infestation, healing, or a life-tied force.",
      "reversed": "Growth becomes corruption."
    },
    {
      "name": "The Emperor",
      "theme": "Authority",
      "upright": "A faction, hierarchy, or command structure intervenes.",
      "reversed": "Oppressive control or blocked access."
    },
    {
      "name": "The Hierophant",
      "theme": "Doctrine and rite",
      "upright": "Divine law, sacred structure, or ritual order enters play.",
      "reversed": "Corrupted rite or rigid dogma harms the hunt."
    },
    {
      "name": "The Lovers",
      "theme": "Bond and choice",
      "upright": "A relationship, pact, or tether defines the case.",
      "reversed": "Betrayal, fracture, or painful severance."
    },
    {
      "name": "The Chariot",
      "theme": "Momentum",
      "upright": "Push the hunt forward fast; chase, pursuit, or acceleration.",
      "reversed": "Loss of control; pace turns hostile."
    },
    {
      "name": "Strength",
      "theme": "Restraint and will",
      "upright": "Gain control over fear, affliction, or pressure.",
      "reversed": "Self-control breaks; the threat gets inside."
    },
    {
      "name": "The Hermit",
      "theme": "Isolation and insight",
      "upright": "A solitary clue, witness, or hidden record becomes key.",
      "reversed": "Lose support; the team is cut off."
    },
    {
      "name": "Wheel of Fortune",
      "theme": "Cycle and reversal",
      "upright": "Shift the case direction, timing, or pressure track.",
      "reversed": "Bad timing or reversal hurts the team."
    },
    {
      "name": "Justice",
      "theme": "Truth and consequence",
      "upright": "Expose a lie, debt, or old wrong tied to the case.",
      "reversed": "False accusation or skewed judgment."
    },
    {
      "name": "The Hanged Man",
      "theme": "Sacrifice",
      "upright": "Progress requires a real cost or delay.",
      "reversed": "A painful stall or wasted opportunity."
    },
    {
      "name": "Death",
      "theme": "Transformation",
      "upright": "The threat changes form; one phase ends and another begins.",
      "reversed": "Mutation or unstable escalation."
    },
    {
      "name": "Temperance",
      "theme": "Balance",
      "upright": "Stabilize a scene, reduce pressure, or control mixed forces.",
      "reversed": "Imbalance doubles the danger."
    },
    {
      "name": "The Devil",
      "theme": "Corruption",
      "upright": "Temptation, possession, affliction, or dark leverage grows.",
      "reversed": "A brief chance to resist, never free."
    },
    {
      "name": "The Tower",
      "theme": "Collapse",
      "upright": "Trigger catastrophe, breach, or structural failure.",
      "reversed": "Collapse is delayed, building dread."
    },
    {
      "name": "The Star",
      "theme": "Hope",
      "upright": "A major clue, recovery window, or moral center appears.",
      "reversed": "False hope or a clue that comforts before it misleads."
    },
    {
      "name": "The Moon",
      "theme": "Illusion",
      "upright": "Confusion, concealment, and false readings cloud the hunt.",
      "reversed": "The hidden thing is forced into view."
    },
    {
      "name": "The Sun",
      "theme": "Clarity",
      "upright": "Expose truth, reveal the path, remove false leads.",
      "reversed": "Success arrives with a cost or arrogant mistake."
    },
    {
      "name": "Judgment",
      "theme": "Reckoning",
      "upright": "Force confrontation, reveal what must be answered.",
      "reversed": "Outcome is postponed, but pressure remains."
    },
    {
      "name": "The World",
      "theme": "Completion",
      "upright": "Resolve a case, close a loop, or mark a milestone.",
      "reversed": "An unfinished thread survives the ending."
    }
  ],
