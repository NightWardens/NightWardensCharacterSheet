rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isSelf(uid) { return signedIn() && request.auth.uid == uid; }
    function isCampaignMember() { return signedIn() && request.auth.uid in resource.data.memberIds; }
    function willBeCampaignMember() { return signedIn() && request.auth.uid in request.resource.data.memberIds; }
    function isCampaignOwner() { return signedIn() && request.auth.uid == resource.data.ownerId; }

    match /users/{uid} {
      allow read, write: if isSelf(uid);
      match /characters/{characterId} {
        allow read, write, delete: if isSelf(uid);
      }
    }

    match /campaigns/{campaignId} {
      allow create: if signedIn() && request.auth.uid in request.resource.data.memberIds;
      allow read: if isCampaignMember();
      allow update: if isCampaignMember() || willBeCampaignMember();
      allow delete: if isCampaignOwner();
    }

    // A short join-code lookup. The app reads this by exact code, then adds the user to the campaign memberIds.
    match /joinCodes/{code} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn();
    }
  }
}
