rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() { return signedIn() && request.auth.token.email == 'geeklitgames@gmail.com'; }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /libraryEntries/{entryId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userEmail == request.auth.token.email);
      allow create, update, delete: if isAdmin();
    }

    match /purchaseClaims/{claimId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
