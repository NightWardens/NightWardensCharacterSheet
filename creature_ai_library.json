  "pressureEscalation": [
    {
      "clockRange": "0",
      "tier": "quiet",
      "stateHint": "watching",
      "description": "One subtle sign, low urgency."
    },
    {
      "clockRange": "1-3",
      "tier": "low",
      "stateHint": "stalking",
      "description": "A second symptom, nearby presence, or witness pressure."
    },
    {
      "clockRange": "4-6",
      "tier": "moderate",
      "stateHint": "hunting",
      "description": "New victim, active manifestation, or direct pressure."
    },
    {
      "clockRange": "7-9",
      "tier": "high",
      "stateHint": "manifesting",
      "description": "Hostile scene, ritual nearing completion, lair revealed."
    },
    {
      "clockRange": "10+",
      "tier": "crisis",
      "stateHint": "cornered",
      "description": "Immediate confrontation, catastrophe, escape, or full manifestation."
    }
