{
  "version": "pass5.1",
  "engine": "Night Wardens Auto-GM Creature AI + Clue Trail",
  "behaviorStates": [
    {
      "id": "dormant",
      "description": "Present but not actively responding yet.",
      "defaultPressure": 0
    },
    {
      "id": "watching",
      "description": "Observing the Wardens, witnesses, or scene from concealment.",
      "defaultPressure": 0
    },
    {
      "id": "stalking",
      "description": "Following or positioning around a target.",
      "defaultPressure": 1
    },
    {
      "id": "hunting",
      "description": "Actively seeking victims or leverage.",
      "defaultPressure": 2
    },
    {
      "id": "manifesting",
      "description": "Revealing stronger supernatural effects or physical presence.",
      "defaultPressure": 2
    },
    {
      "id": "cornered",
      "description": "Dangerous crisis mode; attacks, flees, bargains, or completes ritual.",
      "defaultPressure": 3
    },
    {
      "id": "fleeing",
      "description": "Retreating to anchor, vessel, lair, or next host.",
      "defaultPressure": 0
    },
    {
      "id": "contained",
      "description": "Held by trap, rite, circle, social law, or physical restraint.",
      "defaultPressure": 0
    },
    {
      "id": "banished",
      "description": "Removed from active case unless fallout restores thread.",
      "defaultPressure": 0
    }
  ],
