rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isCampaignMember(campaignId) {
      return signedIn() && exists(/databases/$(database)/documents/campaigns/$(campaignId)) &&
        request.auth.uid in get(/databases/$(database)/documents/campaigns/$(campaignId)).data.memberIds;
    }

    match /campaigns/{campaignId} {
      allow read, update: if isCampaignMember(campaignId);
      allow create: if signedIn() && request.auth.uid in request.resource.data.memberIds;

      match /autoGmCases/{caseId} {
        allow read, write: if isCampaignMember(campaignId);
      }
    }

    match /users/{userId}/privateAutoGmCases/{caseKey} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
  }
}
