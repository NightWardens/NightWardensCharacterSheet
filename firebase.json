{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {"source": "service-worker.js", "headers": [{"key": "Cache-Control", "value": "no-cache"}]},
      {"source": "firebase-config.js", "headers": [{"key": "Cache-Control", "value": "no-cache"}]}
    ]
  },
  "firestore": {"rules": "firestore.rules"}
}
