{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Night Wardens Auto-GM Sign / Clue Schema",
  "type": "object",
  "required": [
    "key",
    "label",
    "type",
    "clue"
  ],
  "properties": {
    "key": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "clue": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "discovered": {
      "type": "boolean"
    },
    "sourceBehavior": {
      "type": "string"
    }
  }
}